# Default development setup: browser calls /api/v1 and Vite proxies /api to the backend.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=https://money.seohamin.com

# Production or direct-call example:
# VITE_API_BASE_URL=https://money.seohamin.com/api/v1

# Alternative split configuration:
# VITE_API_SERVER_URL=https://money.seohamin.com
# VITE_API_PREFIX=/api/v1
